  // ===== SUPABASE =====
  async function sb(table, query = '') {
    try {
      const res = await fetch(`${SUPABASE_URL}/rest/v1/${table}${query}`, { headers });
      return await res.json();
    } catch(e) { return []; }
  }

  async function loadAll() {
    document.getElementById('status-text').textContent = 'Atualizando...';
    await Promise.all([loadLeads(), loadAprovacoes()]);
    document.getElementById('status-text').textContent = 'Ao vivo';
  }

  async function loadLeads() {
    const data = await sb('leads', '?order=data_ultimo_contato.desc.nullslast&limit=50');
    allLeads = Array.isArray(data) ? data : [];
    renderLeads(allLeads);
  }

  function renderLeads(leads) {
    const list = document.getElementById('leads-list');
    if (!leads.length) { list.innerHTML = '<div style="padding:20px;color:var(--muted);font-size:13px">Nenhum lead encontrado</div>'; return; }
    list.innerHTML = leads.map(l => {
      const etapa = (l.etapa || 'consulta').toLowerCase().replace(/ã/g,'a').replace(/ê/g,'e').replace(/ç/g,'c');
      return `<div class="lead-item ${selectedLead?.lead_id === l.lead_id ? 'active' : ''}" onclick="selectLead('${l.lead_id}', this)">
        <div class="lead-name">${l.nome || 'Sem nome'}</div>
        <div class="lead-preview">${l.cnpj || l.whatsapp || '—'}</div>
        <div class="lead-meta">
          <span class="etapa-badge etapa-${etapa}">${l.etapa || 'consulta'}</span>
          <span class="lead-time">${formatTime(l.data_ultimo_contato)}</span>
        </div>
      </div>`;
    }).join('');
  }

  function filterLeads(q) {
    const f = allLeads.filter(l =>
      (l.nome||'').toLowerCase().includes(q.toLowerCase()) ||
      (l.cnpj||'').includes(q) || (l.whatsapp||'').includes(q)
    );
    renderLeads(f);
  }

  async function selectLead(leadId, el) {
    selectedLead = allLeads.find(l => l.lead_id === leadId);
    if (!selectedLead) return;
    document.querySelectorAll('.lead-item').forEach(i => i.classList.remove('active'));
    if (el) el.classList.add('active');
    document.getElementById('chat-header').style.display = 'flex';
    document.getElementById('lead-profile').style.display = 'flex';
    const initials = (selectedLead.nome||'?').split(' ').map(w=>w[0]).join('').slice(0,2).toUpperCase();
    document.getElementById('chat-avatar').textContent = initials;
    document.getElementById('chat-lead-name').textContent = selectedLead.nome || 'Sem nome';
    document.getElementById('chat-lead-sub').textContent = `${selectedLead.cnpj || '—'} · ${selectedLead.whatsapp || '—'}`;
    document.getElementById('profile-cnpj').textContent = selectedLead.cnpj || '—';
    document.getElementById('profile-whatsapp').textContent = selectedLead.whatsapp || '—';
    document.getElementById('profile-etapa').textContent = selectedLead.etapa || '—';
    document.getElementById('profile-situacao').textContent = selectedLead.situacao_cnpj || '—';
    document.getElementById('profile-porte').textContent = selectedLead.porte || '—';
    document.getElementById('profile-cidade').textContent = `${selectedLead.cidade||'—'} / ${selectedLead.estado||'—'}`;
    document.getElementById('profile-orcamento').textContent = selectedLead.status_orcamento || '—';
    const score = selectedLead.score || 0;
    document.getElementById('profile-score').textContent = `${score}/100`;
    document.getElementById('score-fill').style.width = `${score}%`;
    await loadMessages(selectedLead.lead_id, selectedLead.telefone || selectedLead.whatsapp);
  }

  async function loadMessages(leadId, telefone) {
    const area = document.getElementById('messages-area');
    area.innerHTML = '<div class="empty-chat"><span>Carregando mensagens...</span></div>';
    const msgs = await sb('historico_mensagens', `?or=(lead_id.eq.${leadId},telefone.eq.${telefone || 'null'})&order=created_at.asc&limit=100`);
    if (!Array.isArray(msgs) || !msgs.length) { area.innerHTML = '<div class="empty-chat"><span>Nenhuma mensagem encontrada</span></div>'; return; }
    area.innerHTML = msgs.map(m => {
      const isJuliana = m.tipo === 'saida' || m.tipo === 'outgoing' || m.tipo === 'juliana';
      return `<div class="msg ${isJuliana ? 'juliana' : 'lead'}">
        ${isJuliana ? '<div class="msg-sender">Juliana</div>' : ''}
        ${(m.mensagem || '').replace(/\n/g, '<br>')}
        <div class="msg-time">${formatDateTime(m.created_at)}</div>
      </div>`;
    }).join('');
    area.scrollTop = area.scrollHeight;
  }

  // ===== APROVAÇÕES =====
  async function loadAprovacoes() {
    const data = await sb('aprovacoes', '?status=eq.pendente&order=criado_em.desc');
    const list = document.getElementById('aprovacoes-list');
    const badge = document.getElementById('badge-aprovacoes');
    if (!Array.isArray(data) || !data.length) {
      list.innerHTML = '<div class="empty-state">Nenhuma aprovação pendente no momento</div>';
      badge.classList.remove('visible');
      return;
    }
    badge.textContent = data.length;
    badge.classList.add('visible');
    list.innerHTML = data.map(a => `
      <div class="aprovacao-card">
        <div class="aprovacao-icon">⚡</div>
        <div style="flex:1">
          <div class="aprovacao-title">${a.tipo || 'Aprovação Pendente'}</div>
          <div class="aprovacao-desc">${a.descricao || '—'}</div>
          <div class="aprovacao-lead">Lead: ${a.nome_lead || a.whatsapp || '—'}</div>
        </div>
        <div class="aprovacao-actions">
          <button class="btn-approve yes" onclick="responderAprovacao('${a.id}', 'aprovado')">Aprovar</button>
          <button class="btn-approve no" onclick="responderAprovacao('${a.id}', 'negado')">Negar</button>
        </div>
      </div>`).join('');
  }

  async function responderAprovacao(id, status) {
    await fetch(`${SUPABASE_URL}/rest/v1/aprovacoes?id=eq.${id}`, {
      method: 'PATCH', headers,
      body: JSON.stringify({ status, respondido_em: new Date().toISOString() })
    });
    fetch(WEBHOOK_APROVACAO, { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ aprovacao_id: id, status }) }).catch(() => {});
    loadAprovacoes();
  }

  // ===== MOTIVO CHIPS =====
  document.querySelectorAll('.motivo-chip').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.motivo-chip').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      motivoSelecionado = btn.dataset.m;
    });
  });

  // CNPJ mask
  document.getElementById('a-cnpj').addEventListener('input', function() {
    let v = this.value.replace(/\D/g,'');
    v = v.replace(/^(\d{2})(\d)/,'$1.$2');
    v = v.replace(/^(\d{2})\.(\d{3})(\d)/,'$1.$2.$3');
    v = v.replace(/\.(\d{3})(\d)/,'.$1/$2');
    v = v.replace(/(\d{4})(\d)/,'$1-$2');
    this.value = v;
  });

  // ===== DROP ZONE =====
  const dropZone = document.getElementById('drop-zone');

  dropZone.addEventListener('dragover', e => { e.preventDefault(); dropZone.classList.add('dragover'); });
  dropZone.addEventListener('dragleave', () => dropZone.classList.remove('dragover'));
  dropZone.addEventListener('drop', e => {
    e.preventDefault();
    dropZone.classList.remove('dragover');
    handleFiles(e.dataTransfer.files);
  });

  function handleFiles(files) {
    Array.from(files).forEach(file => {
      const isImage = file.type.startsWith('image/');
      const isPdf = file.type === 'application/pdf';
      if (!isImage && !isPdf) return;

      const reader = new FileReader();
      reader.onload = e => {
        const base64 = e.target.result.split(',')[1];
        uploadedFiles.push({ name: file.name, base64, mediaType: file.type, isImage, dataUrl: e.target.result });
        renderPreviews();
      };
      reader.readAsDataURL(file);
    });
  }

  function renderPreviews() {
    const preview = document.getElementById('drop-preview');
    const btnExtrair = document.getElementById('btn-extrair');

    if (!uploadedFiles.length) {
      preview.innerHTML = '';
      btnExtrair.style.display = 'none';
      return;
    }

    preview.innerHTML = uploadedFiles.map((f, i) => `
      <div class="preview-item">
        ${f.isImage ? `<img src="${f.dataUrl}" alt="${f.name}">` : '📄'}
        <span>${f.name}</span>
        <button class="preview-remove" onclick="removeFile(${i})">✕</button>
      </div>`).join('');

    btnExtrair.style.display = 'inline-flex';
    btnExtrair.disabled = false;
  }

  function removeFile(i) {
    uploadedFiles.splice(i, 1);
    renderPreviews();
  }

  // ===== EXTRAÇÃO COM IA =====
  async function extrairDados() {
    if (!uploadedFiles.length) return;

    const btn = document.getElementById('btn-extrair');
    const statusEl = document.getElementById('extract-status');
    btn.disabled = true;
    btn.innerHTML = '<span class="spinner"></span> Analisando arquivos...';
    statusEl.className = 'extract-status running';
    statusEl.textContent = 'IA lendo os documentos...';

    // Monta o conteúdo para o Claude
    const contentBlocks = [];

    // Instrução principal
    contentBlocks.push({
      type: 'text',
      text: `Você é um assistente especializado em leitura de documentos do sistema HubDoDesenvolvedor e consultas de CNPJ do MEI Seguro.

Analise TODOS os arquivos enviados (prints de tela, PDFs, documentos) e extraia os seguintes dados:

1. nome — nome do MEI ou responsável
2. cnpj — CNPJ no formato XX.XXX.XXX/0001-XX
3. whatsapp — telefone com DDI (ex: 5511999999999)
4. divida_ativa — valor numérico em reais da dívida ativa (PGFN)
5. receita_federal — valor numérico em reais de débitos na Receita Federal
6. declaracoes — quantidade numérica de declarações pendentes (DASN)
7. protestos — valor numérico em reais de protestos
8. situacao_cnpj — situação cadastral (ex: ATIVA, INAPTA, SUSPENSA)
9. observacoes — qualquer informação relevante adicional (ramo, cidade, porte, prazo, desenquadramento, alertas)
10. resumo_contexto — resumo da situação fiscal do lead em 2-3 frases diretas para briefing da Juliana

Responda APENAS com JSON válido, sem markdown, sem explicações. Exemplo:
{
  "nome": "João Silva",
  "cnpj": "64.891.367/0001-25",
  "whatsapp": "",
  "divida_ativa": 4654,
  "receita_federal": 7576,
  "declaracoes": 5,
  "protestos": 866,
  "situacao_cnpj": "INAPTA",
  "observacoes": "CNPJ inapto desde 2022. Ramo: comércio varejista. Cidade: São Paulo/SP.",
  "resumo_contexto": "Lead com CNPJ inapto, dívida ativa de R$4.654 na PGFN e débitos de R$7.576 na Receita Federal. Situação grave com risco de inscrição em dívida ativa federal."
}

Se algum campo não estiver presente nos documentos, retorne null para ele.`
    });

    // Adiciona cada arquivo como imagem ou documento
    for (const f of uploadedFiles) {
      if (f.isImage) {
        contentBlocks.push({
          type: 'image',
          source: { type: 'base64', media_type: f.mediaType, data: f.base64 }
        });
      } else if (f.mediaType === 'application/pdf') {
        contentBlocks.push({
          type: 'document',
          source: { type: 'base64', media_type: 'application/pdf', data: f.base64 }
        });
      }
    }

    try {
      const response = await fetch('https://api.anthropic.com/v1/messages', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          model: 'claude-sonnet-4-20250514',
          max_tokens: 1000,
          messages: [{ role: 'user', content: contentBlocks }]
        })
      });

      const data = await response.json();
      const rawText = data.content?.find(b => b.type === 'text')?.text || '';

      let parsed;
      try {
        const clean = rawText.replace(/```json|```/g, '').trim();
        parsed = JSON.parse(clean);
      } catch {
        throw new Error('Resposta da IA não é JSON válido: ' + rawText.slice(0, 200));
      }

      // Preenche os campos
      let preenchidos = 0;

      function setField(id, val, isCnpj = false) {
        if (val === null || val === undefined || val === '') return;
        const el = document.getElementById(id);
        if (!el) return;
        if (isCnpj) {
          let v = String(val).replace(/\D/g,'');
          v = v.replace(/^(\d{2})(\d)/,'$1.$2');
          v = v.replace(/^(\d{2})\.(\d{3})(\d)/,'$1.$2.$3');
          v = v.replace(/\.(\d{3})(\d)/,'.$1/$2');
          v = v.replace(/(\d{4})(\d)/,'$1-$2');
          el.value = v;
        } else {
          el.value = val;
        }
        el.classList.add('filled');
        preenchidos++;
      }

      setField('a-nome', parsed.nome);
      setField('a-cnpj', parsed.cnpj, true);
      setField('a-whatsapp', parsed.whatsapp);
      setField('a-da', parsed.divida_ativa);
      setField('a-rf', parsed.receita_federal);
      setField('a-decl', parsed.declaracoes);
      setField('a-prot', parsed.protestos);

      // Obs e contexto
      const obsPartes = [parsed.situacao_cnpj ? `Situação CNPJ: ${parsed.situacao_cnpj}` : '', parsed.observacoes || ''].filter(Boolean).join('\n');
      if (obsPartes) { document.getElementById('a-obs').value = obsPartes; document.getElementById('a-obs').classList.add('filled'); preenchidos++; }
      if (parsed.resumo_contexto) { document.getElementById('a-contexto').value = parsed.resumo_contexto; document.getElementById('a-contexto').classList.add('filled'); preenchidos++; }

      // Gera o prompt automaticamente
      gerarPromptAcionar();

      statusEl.className = 'extract-status done';
      statusEl.textContent = `✓ ${preenchidos} campos preenchidos automaticamente. Revise e acione.`;
      btn.innerHTML = '✦ Reextrair';
      btn.disabled = false;

    } catch(err) {
      statusEl.className = 'extract-status error';
      statusEl.textContent = 'Erro na extração: ' + err.message;
      btn.innerHTML = '✦ Tentar Novamente';
      btn.disabled = false;
    }
  }

  // ===== GERAR PROMPT =====
  function fmtMoeda(val) {
    if (!val) return null;
    return 'R$ ' + parseFloat(val).toLocaleString('pt-BR', {minimumFractionDigits:2});
  }

  function gerarPromptAcionar() {
    const nome = document.getElementById('a-nome').value.trim() || 'Não informado';
    const cnpj = document.getElementById('a-cnpj').value.trim() || 'Não informado';
    const whatsapp = document.getElementById('a-whatsapp').value.trim() || 'Não informado';
    const contexto = document.getElementById('a-contexto').value.trim() || 'Não informado';
    const instrucao = document.getElementById('a-instrucao').value.trim() || 'Não informado';
    const obs = document.getElementById('a-obs').value.trim();
    const vDA = fmtMoeda(document.getElementById('a-da').value);
    const vRF = fmtMoeda(document.getElementById('a-rf').value);
    const vDecl = document.getElementById('a-decl').value;
    const vProt = fmtMoeda(document.getElementById('a-prot').value);

    let p = `/op\n\nVocê está recebendo um briefing direto do operador humano (João). Leia com atenção, absorva o contexto e execute conforme a instrução. Não invente informações além do que foi passado.\n\n---\n\n`;
    p += `LEAD\nNome: ${nome}\nCNPJ: ${cnpj}\nWhatsApp: ${whatsapp}\n\n`;
    p += `MOTIVO DO ACIONAMENTO: ${motivoSelecionado || 'Não selecionado'}\n\n`;
    p += `CONTEXTO (o que já aconteceu)\n${contexto}\n\n`;
    p += `INSTRUÇÃO (o que Juliana deve fazer)\n${instrucao}\n\n`;

    const dividas = [
      vDA && `Dívida Ativa: ${vDA}`,
      vRF && `Receita Federal: ${vRF}`,
      vDecl && `Declarações Pendentes: ${vDecl} declaração(ões)`,
      vProt && `Protestos: ${vProt}`
    ].filter(Boolean);

    if (dividas.length || obs) {
      p += `SITUAÇÃO DA CONSULTA\n`;
      if (dividas.length) { p += `Dívidas identificadas:\n`; dividas.forEach(d => p += `- ${d}\n`); }
      if (obs) p += `\nObservações: ${obs}\n`;
    }

    document.getElementById('a-prompt').value = p;
    return p;
  }

  // ===== ACIONAR =====
  async function acionarJuliana() {
    const nome = document.getElementById('a-nome').value.trim();
    const whatsapp = document.getElementById('a-whatsapp').value.trim();
    const cnpj = document.getElementById('a-cnpj').value.trim();

    if (!nome || !whatsapp || !cnpj) { showStatus('Preencha nome, CNPJ e WhatsApp.', 'error'); return; }
    if (!motivoSelecionado) { showStatus('Selecione o motivo.', 'error'); return; }

    const prompt = document.getElementById('a-prompt').value.trim() || gerarPromptAcionar();
    const btn = document.querySelector('.btn-acionar');
    btn.disabled = true;
    showStatus('Enviando para Juliana...', 'loading');

    try {
      const res = await fetch(WEBHOOK_OPERADOR, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ prompt, whatsapp, nome, motivo: motivoSelecionado, cnpj: cnpj.replace(/\D/g,'') })
      });
      if (res.ok) {
        showStatus('✓ Juliana acionada com sucesso.', 'success');
        // Reset arquivos
        uploadedFiles = [];
        renderPreviews();
        document.getElementById('extract-status').textContent = '';
        setTimeout(loadLeads, 3000);
      } else {
        showStatus('Erro ao enviar. Verifique o webhook.', 'error');
      }
    } catch(e) { showStatus('Erro de conexão.', 'error'); }
    btn.disabled = false;
  }

  function showStatus(msg, type) {
    const el = document.getElementById('acionar-status');
    el.className = `status-msg ${type}`;
    el.textContent = msg;
  }

  function openAcionar() {
    if (selectedLead) {
      document.getElementById('a-nome').value = selectedLead.nome || '';
      document.getElementById('a-cnpj').value = selectedLead.cnpj || '';
      document.getElementById('a-whatsapp').value = selectedLead.whatsapp || '';
    }
    setPage('acionar', document.querySelectorAll('.nav-tab')[2]);
  }

  // ===== MÉTRICAS =====
  async function loadMetrics() {
    const leads = await sb('leads', '?select=etapa,status_orcamento,comprou');
    const aprovacoes = await sb('aprovacoes', '?status=eq.pendente&select=id');
    if (!Array.isArray(leads)) return;
    document.getElementById('m-total').textContent = leads.length;
    document.getElementById('m-orcamentos').textContent = leads.filter(l => l.status_orcamento && l.status_orcamento !== 'nenhum').length;
    document.getElementById('m-fechamentos').textContent = leads.filter(l => l.comprou).length;
    document.getElementById('m-aprovacoes-count').textContent = Array.isArray(aprovacoes) ? aprovacoes.length : '—';
    document.getElementById('f-consulta').textContent = leads.filter(l => !l.etapa || l.etapa.toLowerCase().includes('consulta')).length;
    document.getElementById('f-consciencia').textContent = leads.filter(l => (l.etapa||'').toLowerCase().includes('consci')).length;
    document.getElementById('f-solucao').textContent = leads.filter(l => (l.etapa||'').toLowerCase().includes('solu')).length;
    document.getElementById('f-orcamento').textContent = leads.filter(l => (l.etapa||'').toLowerCase().includes('or')).length;
    document.getElementById('f-fechamento').textContent = leads.filter(l => (l.etapa||'').toLowerCase().includes('fecha')).length;
  }

  // ===== UTILS =====
  function formatTime(dt) {
    if (!dt) return '';
    const d = new Date(dt), now = new Date(), diff = now - d;
    if (diff < 3600000) return `${Math.floor(diff/60000)}m`;
    if (diff < 86400000) return `${Math.floor(diff/3600000)}h`;
    return d.toLocaleDateString('pt-BR');
  }

  function formatDateTime(dt) {
    if (!dt) return '';
    return new Date(dt).toLocaleString('pt-BR', { day:'2-digit', month:'2-digit', hour:'2-digit', minute:'2-digit' });
  }

  // INIT
  loadAll();
  setInterval(() => {
    loadAprovacoes();
    if (selectedLead) loadMessages(selectedLead.lead_id, selectedLead.telefone || selectedLead.whatsapp);
  }, 15000);
</script>
