<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>LM Inteligente — Command Center</title>
<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
  :root {
    --primary: #1a3a5c;
    --primary-light: #2457a0;
    --accent: #2457a0;
    --accent-dim: #e8f0fb;
    --border: #d4dce8;
    --text: #1a2535;
    --muted: #6b7a8d;
    --bg: #f4f6fa;
    --white: #ffffff;
    --success: #1a7a4a;
    --success-bg: #e8f7ef;
    --danger: #c0392b;
    --danger-bg: #fdf0ee;
    --warn: #b7860a;
    --warn-bg: #fff8e6;
    --surface: #ffffff;
  }

  * { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    font-family: 'Plus Jakarta Sans', sans-serif;
    background: var(--bg);
    color: var(--text);
    height: 100vh;
    overflow: hidden;
    display: flex;
    flex-direction: column;
  }

  .topbar {
    height: 56px;
    background: var(--white);
    border-bottom: 1px solid var(--border);
    display: flex;
    align-items: center;
    padding: 0 24px;
    gap: 24px;
    flex-shrink: 0;
    box-shadow: 0 1px 4px rgba(0,0,0,.04);
  }

  .logo { font-size: 16px; font-weight: 800; color: var(--primary); letter-spacing: -.01em; }
  .logo span { color: var(--primary-light); }

  .live-dot {
    width: 7px; height: 7px;
    background: #22c55e;
    border-radius: 50%;
    animation: pulse 2s infinite;
    margin-left: 4px;
    display: inline-block;
  }

  @keyframes pulse { 0%,100%{opacity:1}50%{opacity:.3} }

  .nav-tabs { display: flex; gap: 2px; margin-left: 16px; }

  .nav-tab {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: 13px;
    font-weight: 600;
    padding: 7px 16px;
    border-radius: 8px;
    border: none;
    background: transparent;
    color: var(--muted);
    cursor: pointer;
    transition: all .15s;
  }

  .nav-tab:hover { background: var(--bg); color: var(--text); }
  .nav-tab.active { background: var(--accent-dim); color: var(--accent); }

  .topbar-right { margin-left: auto; display: flex; align-items: center; gap: 12px; }

  .status-text { font-family: 'DM Mono', monospace; font-size: 11px; color: var(--muted); }

  .badge-notif {
    background: var(--danger);
    color: white;
    font-size: 10px;
    font-weight: 700;
    padding: 2px 6px;
    border-radius: 10px;
    display: none;
    margin-left: 4px;
  }
  .badge-notif.visible { display: inline-block; }

  .btn-refresh {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: 12px;
    font-weight: 600;
    padding: 6px 12px;
    border-radius: 6px;
    border: 1px solid var(--border);
    background: var(--white);
    color: var(--muted);
    cursor: pointer;
    transition: all .15s;
  }
  .btn-refresh:hover { border-color: var(--accent); color: var(--accent); }

  .main { display: flex; flex: 1; overflow: hidden; }
  .page { display: none; width: 100%; }
  .page.active { display: flex; }

  /* CONVERSAS */
  #page-conversas { flex-direction: row; }

  .leads-sidebar {
    width: 300px;
    border-right: 1px solid var(--border);
    background: var(--white);
    display: flex;
    flex-direction: column;
    flex-shrink: 0;
  }

  .sidebar-header {
    padding: 16px;
    border-bottom: 1px solid var(--border);
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .sidebar-title { font-size: 12px; font-weight: 700; letter-spacing: .1em; text-transform: uppercase; color: var(--muted); }

  .search-input {
    margin: 12px 16px;
    width: calc(100% - 32px);
    background: var(--bg);
    border: 1.5px solid var(--border);
    color: var(--text);
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: 13px;
    padding: 9px 12px;
    border-radius: 8px;
    outline: none;
    transition: border-color .15s;
  }
  .search-input:focus { border-color: var(--accent); }

  .leads-list { flex: 1; overflow-y: auto; }

  .lead-item {
    padding: 13px 16px;
    border-bottom: 1px solid var(--border);
    cursor: pointer;
    transition: background .1s;
  }
  .lead-item:hover { background: var(--bg); }
  .lead-item.active { background: var(--accent-dim); border-left: 3px solid var(--accent); }

  .lead-name { font-size: 13px; font-weight: 700; margin-bottom: 3px; color: var(--text); }
  .lead-preview { font-family: 'DM Mono', monospace; font-size: 11px; color: var(--muted); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  .lead-meta { display: flex; align-items: center; gap: 6px; margin-top: 5px; }

  .etapa-badge { font-size: 9px; font-weight: 700; padding: 2px 7px; border-radius: 20px; letter-spacing: .06em; text-transform: uppercase; }
  .etapa-consulta { background: #dbeafe; color: #1d4ed8; }
  .etapa-consciencia { background: #fef3c7; color: #92400e; }
  .etapa-solucao { background: #ede9fe; color: #6d28d9; }
  .etapa-orcamento { background: #d1fae5; color: #065f46; }
  .etapa-fechamento { background: #fee2e2; color: #991b1b; }

  .lead-time { font-family: 'DM Mono', monospace; font-size: 10px; color: var(--muted); margin-left: auto; }

  .chat-area { flex: 1; display: flex; flex-direction: column; background: var(--bg); }

  .chat-header {
    padding: 14px 20px;
    border-bottom: 1px solid var(--border);
    background: var(--white);
    display: flex;
    align-items: center;
    gap: 12px;
    box-shadow: 0 1px 4px rgba(0,0,0,.04);
  }

  .chat-avatar {
    width: 38px; height: 38px;
    background: var(--accent-dim);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 800;
    font-size: 14px;
    color: var(--accent);
    border: 1.5px solid var(--border);
  }

  .chat-lead-name { font-size: 14px; font-weight: 700; }
  .chat-lead-sub { font-family: 'DM Mono', monospace; font-size: 11px; color: var(--muted); margin-top: 2px; }
  .chat-actions { margin-left: auto; display: flex; gap: 8px; }

  .btn-sm {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: 12px;
    font-weight: 600;
    padding: 7px 14px;
    border-radius: 8px;
    border: 1.5px solid var(--border);
    background: var(--white);
    color: var(--muted);
    cursor: pointer;
    transition: all .15s;
  }
  .btn-sm:hover { border-color: var(--accent); color: var(--accent); }
  .btn-sm.primary { background: var(--primary); color: white; border-color: var(--primary); }
  .btn-sm.primary:hover { background: var(--primary-light); border-color: var(--primary-light); }

  .messages-area { flex: 1; overflow-y: auto; padding: 20px; display: flex; flex-direction: column; gap: 10px; }

  .msg { max-width: 68%; padding: 10px 14px; border-radius: 12px; font-size: 13px; line-height: 1.55; }
  .msg.juliana { background: var(--white); border: 1px solid var(--border); align-self: flex-start; border-bottom-left-radius: 4px; box-shadow: 0 1px 3px rgba(0,0,0,.05); }
  .msg.lead { background: var(--primary); color: white; align-self: flex-end; border-bottom-right-radius: 4px; }

  .msg-sender { font-size: 10px; font-weight: 700; color: var(--accent); margin-bottom: 4px; letter-spacing: .06em; text-transform: uppercase; }
  .msg-time { font-family: 'DM Mono', monospace; font-size: 10px; color: var(--muted); margin-top: 4px; text-align: right; }
  .msg.lead .msg-time { color: rgba(255,255,255,.6); }

  .empty-chat { flex: 1; display: flex; align-items: center; justify-content: center; color: var(--muted); font-size: 13px; flex-direction: column; gap: 8px; }

  .lead-profile { width: 240px; border-left: 1px solid var(--border); background: var(--white); overflow-y: auto; }

  .profile-section { padding: 14px 16px; border-bottom: 1px solid var(--border); }
  .profile-label { font-size: 10px; font-weight: 700; letter-spacing: .1em; text-transform: uppercase; color: var(--muted); margin-bottom: 5px; }
  .profile-value { font-family: 'DM Mono', monospace; font-size: 12px; color: var(--text); line-height: 1.5; }

  .score-bar { height: 5px; background: var(--bg); border-radius: 3px; overflow: hidden; margin-top: 6px; border: 1px solid var(--border); }
  .score-fill { height: 100%; background: var(--accent); border-radius: 3px; transition: width .3s; }

  /* APROVAÇÕES */
  #page-aprovacoes { flex-direction: column; padding: 28px; overflow-y: auto; background: var(--bg); }

  .page-title { font-size: 22px; font-weight: 800; color: var(--primary); }
  .page-sub { font-family: 'DM Mono', monospace; font-size: 12px; color: var(--muted); margin-top: 4px; margin-bottom: 24px; }

  .aprovacao-card {
    background: var(--white);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 18px 20px;
    display: flex;
    align-items: center;
    gap: 16px;
    margin-bottom: 12px;
    box-shadow: 0 1px 4px rgba(0,0,0,.04);
    border-left: 4px solid var(--warn);
  }

  .aprovacao-icon { width: 42px; height: 42px; border-radius: 10px; background: var(--warn-bg); display: flex; align-items: center; justify-content: center; font-size: 20px; flex-shrink: 0; }
  .aprovacao-title { font-size: 14px; font-weight: 700; margin-bottom: 3px; }
  .aprovacao-desc { font-family: 'DM Mono', monospace; font-size: 12px; color: var(--muted); }
  .aprovacao-lead { font-size: 11px; color: var(--muted); margin-top: 4px; }
  .aprovacao-actions { margin-left: auto; display: flex; gap: 8px; }

  .btn-approve { font-family: 'Plus Jakarta Sans', sans-serif; font-size: 12px; font-weight: 700; padding: 8px 18px; border-radius: 8px; border: none; cursor: pointer; transition: opacity .15s; }
  .btn-approve.yes { background: var(--primary); color: white; }
  .btn-approve.no { background: var(--danger-bg); color: var(--danger); border: 1.5px solid var(--danger); }
  .btn-approve:hover { opacity: .85; }

  .empty-state { text-align: center; padding: 60px 20px; color: var(--muted); font-size: 14px; }

  /* ACIONAR */
  #page-acionar { flex-direction: column; overflow-y: auto; padding: 28px; background: var(--bg); }

  .acionar-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; max-width: 900px; margin-top: 4px; }

  .form-card { background: var(--white); border: 1px solid var(--border); border-radius: 12px; padding: 22px; box-shadow: 0 1px 4px rgba(0,0,0,.04); }
  .form-card.full { grid-column: 1 / -1; }

  .form-section-title {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: .12em;
    text-transform: uppercase;
    color: var(--muted);
    margin-bottom: 14px;
    padding-bottom: 10px;
    border-bottom: 1px solid var(--border);
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .field { margin-bottom: 12px; }
  .field:last-child { margin-bottom: 0; }
  .field label { display: block; font-size: 11px; font-weight: 600; color: var(--muted); text-transform: uppercase; letter-spacing: .08em; margin-bottom: 5px; }
  .field input, .field textarea {
    width: 100%;
    background: var(--bg);
    border: 1.5px solid var(--border);
    color: var(--text);
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: 13px;
    padding: 10px 13px;
    border-radius: 8px;
    outline: none;
    transition: border-color .15s;
  }
  .field input:focus, .field textarea:focus { border-color: var(--accent); background: white; }
  .field textarea { resize: vertical; min-height: 75px; line-height: 1.6; }
  .field-row { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; }

  .motivo-row { display: flex; flex-wrap: wrap; gap: 8px; }
  .motivo-chip {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: 12px;
    font-weight: 600;
    padding: 7px 16px;
    border-radius: 20px;
    border: 1.5px solid var(--border);
    background: var(--bg);
    color: var(--muted);
    cursor: pointer;
    transition: all .15s;
  }
  .motivo-chip:hover { border-color: var(--accent); color: var(--accent); }
  .motivo-chip.active { border-color: var(--accent); background: var(--accent-dim); color: var(--accent); }

  .prompt-textarea {
    width: 100%;
    background: var(--bg);
    border: 1.5px solid var(--border);
    color: var(--text);
    font-family: 'DM Mono', monospace;
    font-size: 11.5px;
    padding: 13px;
    border-radius: 8px;
    outline: none;
    resize: vertical;
    min-height: 130px;
    line-height: 1.7;
    transition: border-color .15s;
  }
  .prompt-textarea:focus { border-color: var(--accent); background: white; }

  .btn-gerar {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: 12px;
    font-weight: 600;
    padding: 7px 14px;
    border-radius: 7px;
    border: 1.5px solid var(--border);
    background: white;
    color: var(--muted);
    cursor: pointer;
    transition: all .15s;
  }
  .btn-gerar:hover { border-color: var(--accent); color: var(--accent); }

  .btn-acionar {
    width: 100%;
    background: var(--primary);
    color: white;
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: 14px;
    font-weight: 700;
    padding: 14px;
    border: none;
    border-radius: 10px;
    cursor: pointer;
    transition: background .15s;
    margin-top: 12px;
    letter-spacing: .02em;
  }
  .btn-acionar:hover { background: var(--primary-light); }
  .btn-acionar:disabled { opacity: .4; cursor: not-allowed; }

  .status-msg {
    display: none;
    font-family: 'DM Mono', monospace;
    font-size: 12px;
    padding: 10px 14px;
    border-radius: 8px;
    margin-top: 10px;
    text-align: center;
    font-weight: 500;
  }
  .status-msg.success { display:block; background:var(--success-bg); color:var(--success); border:1px solid #a8dfc0; }
  .status-msg.error { display:block; background:var(--danger-bg); color:var(--danger); border:1px solid #f0b8b2; }
  .status-msg.loading { display:block; background:var(--warn-bg); color:var(--warn); border:1px solid #f0d88a; }

  /* ===== DROP ZONE ===== */
  .drop-zone {
    grid-column: 1 / -1;
    background: var(--white);
    border: 2px dashed var(--border);
    border-radius: 12px;
    padding: 28px 22px;
    text-align: center;
    cursor: pointer;
    transition: all .2s;
    position: relative;
  }
  .drop-zone:hover, .drop-zone.dragover {
    border-color: var(--accent);
    background: var(--accent-dim);
  }
  .drop-zone input[type="file"] {
    position: absolute;
    inset: 0;
    opacity: 0;
    cursor: pointer;
    width: 100%;
    height: 100%;
  }
  .drop-icon { font-size: 32px; margin-bottom: 8px; }
  .drop-title { font-size: 14px; font-weight: 700; color: var(--primary); margin-bottom: 4px; }
  .drop-sub { font-family: 'DM Mono', monospace; font-size: 11px; color: var(--muted); }

  .drop-preview {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-top: 14px;
    justify-content: center;
  }

  .preview-item {
    position: relative;
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 8px 12px;
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 12px;
    font-weight: 600;
    color: var(--text);
  }

  .preview-item img {
    width: 40px;
    height: 40px;
    object-fit: cover;
    border-radius: 4px;
    border: 1px solid var(--border);
  }

  .preview-remove {
    background: none;
    border: none;
    cursor: pointer;
    color: var(--danger);
    font-size: 14px;
    padding: 0 2px;
    line-height: 1;
  }

  .btn-extrair {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: 13px;
    font-weight: 700;
    padding: 10px 20px;
    border-radius: 8px;
    border: none;
    background: var(--accent);
    color: white;
    cursor: pointer;
    transition: opacity .15s;
    margin-top: 14px;
  }
  .btn-extrair:hover { opacity: .88; }
  .btn-extrair:disabled { opacity: .4; cursor: not-allowed; }

  .extract-status {
    margin-top: 10px;
    font-family: 'DM Mono', monospace;
    font-size: 12px;
    color: var(--muted);
    min-height: 18px;
  }

  .extract-status.running { color: var(--warn); }
  .extract-status.done { color: var(--success); }
  .extract-status.error { color: var(--danger); }

  .field input.filled { border-color: var(--success); background: var(--success-bg); }

  /* MÉTRICAS */
  #page-metricas { flex-direction: column; padding: 28px; overflow-y: auto; background: var(--bg); gap: 20px; }
  .metrics-grid { display: grid; grid-template-columns: repeat(4,1fr); gap: 16px; }

  .metric-card { background: var(--white); border: 1px solid var(--border); border-radius: 12px; padding: 20px; box-shadow: 0 1px 4px rgba(0,0,0,.04); }
  .metric-label { font-size: 11px; font-weight: 700; letter-spacing: .1em; text-transform: uppercase; color: var(--muted); margin-bottom: 8px; }
  .metric-value { font-size: 36px; font-weight: 800; color: var(--primary); line-height: 1; }
  .metric-sub { font-family: 'DM Mono', monospace; font-size: 11px; color: var(--muted); margin-top: 4px; }

  .funnel-row { display: grid; grid-template-columns: repeat(5,1fr); gap: 14px; }
  .funnel-step { background: var(--white); border: 1px solid var(--border); border-radius: 12px; padding: 18px; text-align: center; box-shadow: 0 1px 4px rgba(0,0,0,.04); }
  .funnel-count { font-size: 32px; font-weight: 800; margin-bottom: 5px; }
  .funnel-label { font-size: 11px; font-weight: 700; letter-spacing: .08em; text-transform: uppercase; color: var(--muted); }

  ::-webkit-scrollbar { width: 4px; }
  ::-webkit-scrollbar-track { background: transparent; }
  ::-webkit-scrollbar-thumb { background: var(--border); border-radius: 2px; }

  /* Spinner */
  @keyframes spin { to { transform: rotate(360deg); } }
  .spinner { display: inline-block; width: 14px; height: 14px; border: 2px solid rgba(255,255,255,.4); border-top-color: white; border-radius: 50%; animation: spin .6s linear infinite; }
</style>
</head>
<body>

<div class="topbar">
  <div class="logo">LM <span>Inteligente</span> <span class="live-dot"></span></div>
  <nav class="nav-tabs">
    <button class="nav-tab active" onclick="setPage('conversas', this)">Conversas</button>
    <button class="nav-tab" onclick="setPage('aprovacoes', this)">Aprovações <span class="badge-notif" id="badge-aprovacoes"></span></button>
    <button class="nav-tab" onclick="setPage('acionar', this)">Acionar Juliana</button>
    <button class="nav-tab" onclick="setPage('metricas', this)">Métricas</button>
  </nav>
  <div class="topbar-right">
    <span class="status-text" id="status-text">Conectando...</span>
    <button class="btn-refresh" onclick="loadAll()">Atualizar</button>
  </div>
</div>

<div class="main">

  <!-- CONVERSAS -->
  <div class="page active" id="page-conversas">
    <div class="leads-sidebar">
      <div class="sidebar-header">
        <span class="sidebar-title">Leads</span>
        <button class="btn-refresh" onclick="loadLeads()">↺</button>
      </div>
      <input class="search-input" type="text" placeholder="Buscar lead..." oninput="filterLeads(this.value)">
      <div class="leads-list" id="leads-list">
        <div style="padding:20px;color:var(--muted);font-size:13px">Carregando...</div>
      </div>
    </div>

    <div class="chat-area">
      <div class="chat-header" id="chat-header" style="display:none">
        <div class="chat-avatar" id="chat-avatar">?</div>
        <div>
          <div class="chat-lead-name" id="chat-lead-name">—</div>
          <div class="chat-lead-sub" id="chat-lead-sub">—</div>
        </div>
        <div class="chat-actions">
          <button class="btn-sm" onclick="openAcionar()">Acionar</button>
        </div>
      </div>
      <div class="messages-area" id="messages-area">
        <div class="empty-chat">
          <span style="font-size:40px">💬</span>
          <span>Selecione um lead para ver a conversa</span>
        </div>
      </div>
    </div>

    <div class="lead-profile" id="lead-profile" style="display:none">
      <div class="profile-section"><div class="profile-label">CNPJ</div><div class="profile-value" id="profile-cnpj">—</div></div>
      <div class="profile-section"><div class="profile-label">WhatsApp</div><div class="profile-value" id="profile-whatsapp">—</div></div>
      <div class="profile-section"><div class="profile-label">Etapa</div><div class="profile-value" id="profile-etapa">—</div></div>
      <div class="profile-section">
        <div class="profile-label">Score</div>
        <div class="profile-value" id="profile-score">—</div>
        <div class="score-bar"><div class="score-fill" id="score-fill" style="width:0%"></div></div>
      </div>
      <div class="profile-section"><div class="profile-label">Situação CNPJ</div><div class="profile-value" id="profile-situacao">—</div></div>
      <div class="profile-section"><div class="profile-label">Porte</div><div class="profile-value" id="profile-porte">—</div></div>
      <div class="profile-section"><div class="profile-label">Cidade</div><div class="profile-value" id="profile-cidade">—</div></div>
      <div class="profile-section"><div class="profile-label">Status Orçamento</div><div class="profile-value" id="profile-orcamento">—</div></div>
    </div>
  </div>

  <!-- APROVAÇÕES -->
  <div class="page" id="page-aprovacoes">
